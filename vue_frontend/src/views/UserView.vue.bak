<script>
import { ref, onMounted, onBeforeUnmount, inject, watch } from "vue";
import { useRouter, useRoute } from "vue-router";
import { authApi, userApi, notificationApi } from "../utils/api";
import { notificationWS } from "../utils/websocket";

export default {
  name: "UserView",
  setup() {
    const router = useRouter();
    const route = useRoute();
    const updateLoginStatus = inject("updateLoginStatus");
    const isLoggedIn = inject("isLoggedIn");
    const isDarkMode = inject("isDarkMode");
    const toggleDarkMode = inject("toggleDarkMode");
    const username = ref("");
    const userEmail = ref("");
    const isLoggingOut = ref(false);
    const bgGradientComplete = ref(false);
    const isLeaving = ref(false);
    const isEntering = ref(true);
    let navigationGuard = null;
    let unsubscribeNotification = null;

    // 瀵艰埅鏍忛€変腑椤?    const activeNavItem = ref("favorites");

    // 娑堟伅瀵艰埅鏍?    const activeMessageTab = ref("likes");

    // 閫氱煡鍒楄〃
    const likeNotifications = ref([]);
    const replyNotifications = ref([]);
    const followNotifications = ref([]);

    // 鏁版嵁鎸囨爣瀵艰埅
    const activeStatsTab = ref(null);
    const likesCount = ref(0);
    const followingCount = ref(0);
    const followersCount = ref(0);

    // 鍏虫敞鍒楄〃
    const followingList = ref([]);
    const followingLoading = ref(false);

    // 绮変笣鍒楄〃
    const followersList = ref([]);
    const followersLoading = ref(false);

    // 鎼滅储鍔熻兘
    const searchQuery = ref("");
    const showUserMenu = ref(false);

    // 澶村儚鐩稿叧
    const userAvatar = ref("");
    const showAvatarOverlay = ref(false);
    const fileInput = ref(null);

    // 鏀惰棌鐨勫笘瀛愭暟鎹紙浠庡悗绔媺鍙栵紝鏆傛棤鎺ュ彛鏃朵负绌猴級
    const favoriteThreads = ref([]);
    const favoritesLoading = ref(false);

    // 鏍煎紡鍖栨椂闂村嚱鏁?    const formatTime = (timeString) => {
      const date = new Date(timeString);
      return date.toLocaleString("zh-CN", {
        year: "numeric",
        month: "2-digit",
        day: "2-digit",
        hour: "2-digit",
        minute: "2-digit",
      });
    };

    // 缂栬緫涓汉璧勬枡
    const editUsername = ref("");
    const editBio = ref("");
    const editBirthday = ref("");
    const editGender = ref("");
    const editOccupation = ref("");

    // 淇濆瓨涓汉璧勬枡
    const handleSaveProfile = async () => {
      try {
        const profileData = {
          bio: editBio.value,
          birthday: editBirthday.value || null,
          gender: editGender.value || null,
          occupation: editOccupation.value || null,
        };
        const response = await userApi.updateProfile(profileData);
        if (response.data) {
          const p = response.data;
          if (p.bio !== undefined) editBio.value = p.bio || "";
          if (p.birthday !== undefined) editBirthday.value = p.birthday || "";
          if (p.gender !== undefined) editGender.value = p.gender || "";
          if (p.occupation !== undefined)
            editOccupation.value = p.occupation || "";
        }
        alert("涓汉璧勬枡淇濆瓨鎴愬姛");
      } catch (error) {
        console.error("淇濆瓨涓汉璧勬枡澶辫触:", error);
        alert("淇濆瓨澶辫触锛岃绋嶅悗閲嶈瘯");
      }
    };

    // 瑙﹀彂鏂囦欢閫夋嫨
    const triggerFileInput = () => {
      fileInput.value.click();
    };

    // 澶勭悊澶村儚鏇存崲
    const handleAvatarChange = async (event) => {
      const file = event.target.files[0];
      if (!file) return;

      if (!file.type.startsWith("image/")) {
        alert("璇烽€夋嫨鍥剧墖鏂囦欢");
        return;
      }

      const maxSize = 5 * 1024 * 1024;
      if (file.size > maxSize) {
        alert("鍥剧墖澶у皬涓嶈兘瓒呰繃5MB");
        return;
      }

      try {
        const response = await userApi.uploadAvatar(file);
        // API 杩斿洖 ResultString: { code, message, data: "url_string" }
        if (response.data) {
          userAvatar.value = response.data;
          alert("澶村儚涓婁紶鎴愬姛");
        }
      } catch (error) {
        console.error("涓婁紶澶村儚澶辫触:", error);
        alert("涓婁紶澶辫触锛岃绋嶅悗閲嶈瘯");
      }
    };

    // 鑾峰彇褰撳墠鐧诲綍鐢ㄦ埛淇℃伅锛堝惈瀹屾暣 profile锛?    const fetchUserInfo = async () => {
      // 鍏堜粠 token 鍙栫敤鎴峰悕浣滀负鍒濆鍊?      const nameFromToken = authApi.getUsernameFromToken();
      if (nameFromToken) {
        username.value = nameFromToken;
        editUsername.value = nameFromToken;
      } else {
        const remembered = localStorage.getItem("rememberedUsername");
        username.value = remembered || "鐢ㄦ埛";
        editUsername.value = username.value;
      }
      // 浠庡悗绔媺鍙栧畬鏁?profile
      try {
        const res = await userApi.getCurrentProfile();
        if (res.data) {
          const p = res.data;
          if (p.username) {
            username.value = p.username;
            editUsername.value = p.username;
          }
          if (p.bio) editBio.value = p.bio;
          if (p.avatar) userAvatar.value = p.avatar;
          if (p.birthday) editBirthday.value = p.birthday;
          if (p.gender) editGender.value = p.gender;
          if (p.occupation) editOccupation.value = p.occupation;
          likesCount.value = p.likeCount || 0;
          followingCount.value = p.followingCount || 0;
          followersCount.value = p.followerCount || 0;
        }
      } catch (error) {
        console.error("鑾峰彇鐢ㄦ埛璧勬枡澶辫触:", error);
      }
    };

    // 鍔犺浇閫氱煡鍒楄〃
    const normalizeNotificationType = (type) =>
      typeof type === "string" ? type.toUpperCase() : "";

    const isLikeNotification = (type) => {
      const normalized = normalizeNotificationType(type);
      return normalized === "LIKE" || normalized.startsWith("LIKE_");
    };

    const isReplyNotification = (type) => {
      const normalized = normalizeNotificationType(type);
      return normalized === "REPLY" || normalized.startsWith("REPLY_");
    };

    const isFollowNotification = (type) => {
      const normalized = normalizeNotificationType(type);
      return normalized === "FOLLOW" || normalized.startsWith("FOLLOW_");
    };

    const prependNotification = (listRef, notification) => {
      if (!notification || !notification.id) {
        return false;
      }
      const exists = listRef.value.some((item) => item.id === notification.id);
      if (exists) {
        return false;
      }
      listRef.value.unshift({
        ...notification,
        isRead: notification.isRead ?? false,
      });
      return true;
    };

    // 鍔犺浇閫氱煡鍒楄〃
    const loadNotifications = async () => {
      try {
        const res = await notificationApi.getNotifications({
          page: 1,
          size: 50,
        });
        if (res.data?.records) {
          likeNotifications.value = res.data.records.filter((n) =>
            isLikeNotification(n.type),
          );
          replyNotifications.value = res.data.records.filter((n) =>
            isReplyNotification(n.type),
          );
          followNotifications.value = res.data.records.filter((n) =>
            isFollowNotification(n.type),
          );
        }
      } catch (error) {
        console.error("鍔犺浇閫氱煡澶辫触:", error);
      }
    };

    // 澶勭悊WebSocket閫氱煡
    const handleNotification = (notification) => {
      if (isLikeNotification(notification?.type)) {
        const inserted = prependNotification(likeNotifications, notification);
        if (inserted) {
          likesCount.value++;
        }
      } else if (isReplyNotification(notification?.type)) {
        prependNotification(replyNotifications, notification);
      } else if (isFollowNotification(notification?.type)) {
        const inserted = prependNotification(followNotifications, notification);
        if (inserted) {
          followersCount.value++;
        }
      }
    };

    // 澶勭悊閫氱煡鐐瑰嚮锛堟爣璁颁负宸茶锛?    const handleNotificationClick = async (notif) => {
      if (notif.isRead) return;
      try {
        await notificationApi.markRead(notif.id);
        notif.isRead = true;
      } catch (error) {
        console.error("鏍囪宸茶澶辫触:", error);
      }
    };

    // 鍏ㄩ儴宸茶
    const markAllRead = async () => {
      try {
        await notificationApi.markAllRead();
        likeNotifications.value.forEach(n => n.isRead = true);
        replyNotifications.value.forEach(n => n.isRead = true);
        followNotifications.value.forEach(n => n.isRead = true);
      } catch (error) {
        console.error("鍏ㄩ儴宸茶澶辫触:", error);
      }
    };

    // 閫€鍑虹櫥褰?    const handleLogout = async () => {
      isLoggingOut.value = true;
      try {
        // 璋冪敤閫€鍑虹櫥褰旳PI
        await authApi.logout();
        console.log("閫€鍑虹櫥褰曟垚鍔?);

        // 娓呴櫎鏈湴瀛樺偍鐨勭敤鎴蜂俊鎭拰Token
        localStorage.removeItem("accessToken");
        localStorage.removeItem("refreshToken");
        localStorage.removeItem("rememberedUsername");
        localStorage.removeItem("auth_token");

        // 鏇存柊鍏ㄥ眬鐧诲綍鐘舵€?        updateLoginStatus(false);

        // 瀵艰埅鍒颁富椤碉紙璺敱瀹堝崼浼氳Е鍙戠寮€鍔ㄧ敾锛?        router.push("/");
      } catch (error) {
        console.error("閫€鍑虹櫥褰曞け璐?", error);
        // 鍗充娇API璋冪敤澶辫触锛屼粛鐒舵竻闄ゆ湰鍦板瓨鍌ㄥ苟璺宠浆鍒颁富椤?        localStorage.removeItem("accessToken");
        localStorage.removeItem("refreshToken");
        localStorage.removeItem("rememberedUsername");
        localStorage.removeItem("auth_token");

        // 鏇存柊鍏ㄥ眬鐧诲綍鐘舵€?        updateLoginStatus(false);

        // 瀵艰埅鍒颁富椤碉紙璺敱瀹堝崼浼氳Е鍙戠寮€鍔ㄧ敾锛?        router.push("/");
      } finally {
        isLoggingOut.value = false;
      }
    };

    // 鐩戝惉 activeStatsTab 鍙樺寲
    watch(activeStatsTab, (newTab) => {
      if (newTab === "following") {
        fetchFollowing();
      } else if (newTab === "followers") {
        fetchFollowers();
      }
    });

    // 401 鍚庣敤鎴烽噸鏂扮櫥褰曟椂锛岃嚜鍔ㄩ噸鏂板姞杞界敤鎴蜂俊鎭?    watch(isLoggedIn, (newValue, oldValue) => {
      if (newValue && !oldValue) {
        fetchUserInfo();
      }
    });

    // 椤甸潰鎸傝浇鏃惰幏鍙栫敤鎴蜂俊鎭?    onMounted(() => {
      // 鏈櫥褰曞垯璺冲洖涓婚〉骞跺脊鍑虹櫥褰曟
      if (!authApi.isAuthenticated()) {
        window.dispatchEvent(new CustomEvent("open-login-modal"));
        router.push("/");
        return;
      }

      if (route.query.tab) {
        activeNavItem.value = route.query.tab;
      }
      if (route.query.messageTab) {
        activeMessageTab.value = route.query.messageTab;
      }
      if (route.query.statsTab) {
        activeStatsTab.value = route.query.statsTab;
        activeNavItem.value = null;
      }
      fetchUserInfo();
      fetchStats();
      loadNotifications();

      // 杩炴帴WebSocket
      notificationWS.connect();
      unsubscribeNotification = notificationWS.onNotification(handleNotification);

      // 杩涘叆鍔ㄧ敾锛氬欢杩熸竻闄?isEntering锛岃 keyframe 鍔ㄧ敾瀹屾暣鎾斁
      setTimeout(() => {
        isEntering.value = false;
      }, 600);

      // 瑙﹀彂鑳屾櫙娓愬彉鍔ㄧ敾
      setTimeout(() => {
        bgGradientComplete.value = true;

        // 鑳屾櫙娓愬彉瀹屾垚鍚庤Е鍙戝崱鐗囧脊鍑哄姩鐢?        setTimeout(() => {
          // 鍔ㄧ敾瀹屾垚
        }, 300); // 0.3绉掕儗鏅笎鍙樻椂闂?      }, 100); // 缁橠OM涓€鐐规椂闂存覆鏌?
      // 璁剧疆瀵艰埅瀹堝崼
      navigationGuard = router.beforeEach((to, from, next) => {
        if (from.path === route.path) {
          isLeaving.value = true;
          setTimeout(() => {
            next();
          }, 500);
        } else {
          next();
        }
      });
    });

    // 缁勪欢鍗歌浇鏃舵竻闄ゅ鑸畧鍗?    onBeforeUnmount(() => {
      if (navigationGuard) {
        navigationGuard();
      }
      if (unsubscribeNotification) {
        unsubscribeNotification();
        unsubscribeNotification = null;
      }
    });

    // 澶勭悊鎼滅储
    const handleSearch = () => {
      if (searchQuery.value.trim()) {
        console.log("鎼滅储鍐呭:", searchQuery.value);
        // 杩欓噷鍙互娣诲姞鎼滅储閫昏緫锛屼緥濡傝皟鐢ˋPI鎴栬繃婊ゆ湰鍦版暟鎹?        // 鏆傛椂鍙墦鍗版悳绱㈠唴瀹?      }
    };

    // 鑾峰彇缁熻鏁版嵁锛堢敱 fetchUserInfo 涓殑 getCurrentProfile 缁熶竴澶勭悊锛?    const fetchStats = async () => {};

    // 鑾峰彇鍏虫敞鍒楄〃
    const fetchFollowing = async () => {
      followingLoading.value = true;
      try {
        // TODO: 璋冪敤鍚庣鎺ュ彛
        // const data = await userApi.getFollowing();
        // followingList.value = data;
        followingList.value = [];
      } catch (error) {
        console.error("鑾峰彇鍏虫敞鍒楄〃澶辫触:", error);
      } finally {
        followingLoading.value = false;
      }
    };

    // 鑾峰彇绮変笣鍒楄〃
    const fetchFollowers = async () => {
      followersLoading.value = true;
      try {
        // TODO: 璋冪敤鍚庣鎺ュ彛
        // const data = await userApi.getFollowers();
        // followersList.value = data;
        followersList.value = [];
      } catch (error) {
        console.error("鑾峰彇绮変笣鍒楄〃澶辫触:", error);
      } finally {
        followersLoading.value = false;
      }
    };

    // 鍙栨秷鍏虫敞
    const handleUnfollow = async (userId) => {
      // TODO: 璋冪敤鍚庣鎺ュ彛
      // await userApi.unfollow(userId);
      console.log("鍙栨秷鍏虫敞鐢ㄦ埛:", userId);
      alert("鍙栨秷鍏虫敞鎴愬姛");
      fetchFollowing();
    };

    // 鍥炲叧
    const handleFollowBack = async (userId) => {
      // TODO: 璋冪敤鍚庣鎺ュ彛
      // await userApi.follow(userId);
      console.log("鍥炲叧鐢ㄦ埛:", userId);
      alert("鍏虫敞鎴愬姛");
      fetchFollowers();
    };

    // 澶勭悊鏁版嵁鎸囨爣鐐瑰嚮
    const handleStatsClick = (tab) => {
      activeStatsTab.value = tab;
      if (tab === "likes") {
        activeNavItem.value = "messages";
        activeMessageTab.value = "likes";
      } else {
        activeNavItem.value = null;
      }
    };

    return {
      username,
      userEmail,
      isLoggingOut,
      handleLogout,
      bgGradientComplete,
      isLeaving,
      isEntering,
      activeNavItem,
      activeMessageTab,
      likeNotifications,
      replyNotifications,
      followNotifications,
      isLoggedIn,
      isDarkMode,
      toggleDarkMode,
      searchQuery,
      showUserMenu,
      handleSearch,
      favoriteThreads,
      favoritesLoading,
      formatTime,
      editUsername,
      editBio,
      editBirthday,
      editGender,
      editOccupation,
      handleSaveProfile,
      userAvatar,
      showAvatarOverlay,
      fileInput,
      triggerFileInput,
      handleAvatarChange,
      activeStatsTab,
      likesCount,
      followingCount,
      followersCount,
      followingList,
      followingLoading,
      followersList,
      followersLoading,
      handleUnfollow,
      handleFollowBack,
      handleStatsClick,
    };
  },
};
</script>

