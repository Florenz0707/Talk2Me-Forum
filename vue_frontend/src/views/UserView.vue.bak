            <!-- 璁剧疆鍐呭 -->
            <div v-else-if="activeNavItem === 'settings'">
              <h2>璁剧疆</h2>
              <div class="settings-list">
                <div class="setting-item">
                  <span>閫氱煡璁剧疆</span>
                  <label class="switch">
                    <input type="checkbox" checked />
                    <span class="slider"></span>
                  </label>
                </div>
                <div class="setting-item">
                  <span>闅愮璁剧疆</span>
                  <label class="switch">
                    <input type="checkbox" checked />
                    <span class="slider"></span>
                  </label>
                </div>
                <div class="setting-item">
                  <span>娣辫壊妯″紡</span>
                  <label class="switch">
                    <input
                      type="checkbox"
                      :checked="isDarkMode"
                      @change="toggleDarkMode"
                    />
