                    class="form-input"
                  />
                </div>
                <div class="form-group">
                  <label>涓€х鍚?/label>
                  <textarea v-model="editBio" class="form-textarea"></textarea>
                </div>
                <div class="form-group">
                  <label>鐢熸棩</label>
                  <input
                    type="date"
                    v-model="editBirthday"
                    class="form-input"
                  />
                </div>
                <div class="form-group">
                  <label>鎬у埆</label>
                  <select v-model="editGender" class="form-input">
                    <option value="">璇烽€夋嫨</option>
                    <option value="MALE">鐢?/option>
                    <option value="FEMALE">濂?/option>
                    <option value="OTHER">鍏朵粬</option>
                  </select>
                </div>
                <div class="form-group">
                  <label>鑱屼笟</label>
                  <input
                    type="text"
                    v-model="editOccupation"
                    class="form-input"
                    placeholder="璇疯緭鍏ヨ亴涓?
                  />
                </div>
                <button class="save-btn" @click="handleSaveProfile">
                  淇濆瓨淇敼
                </button>
